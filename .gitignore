# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local database
/data/

# raw GLTF source models (converted to GLB in public/models/)
iphone_17_pro_max/
macbook_pro_m3_16_inch_2024/

# QA / debug screenshots (root-level artifacts from review sessions)
*.png
*.jpeg
*.jpg
!public/**/*.png
!public/**/*.jpeg
!public/**/*.jpg
!src/**/*.png
!src/**/*.jpeg
!src/**/*.jpg

# Playwright MCP artifacts
.playwright-mcp/

# Review screenshots
.review-screenshots/
.ux-review/
